{
  "name": "whatsapp-flows-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm run lint:root",
    "lint:fix": "turbo run lint:fix && pnpm run lint:root:fix",
    "lint:root": "eslint . --ignore-pattern 'packages/**' --ignore-pattern 'examples/**'",
    "lint:root:fix": "pnpm run lint:root -- --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,mjs,cjs}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,mjs,cjs}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "oxfmt": "^0.51.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
