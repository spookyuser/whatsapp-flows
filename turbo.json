{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "//#test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "packages/*/src/**",
        "packages/*/test/**",
        "fixtures/**"
      ]
    }
  }
}
